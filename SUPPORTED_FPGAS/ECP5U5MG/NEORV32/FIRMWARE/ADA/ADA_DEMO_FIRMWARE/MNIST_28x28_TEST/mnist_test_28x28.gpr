with "config/mnist_test_28x28_config.gpr";
with "bare_runtime.gpr";
with "neorv32_hal.gpr";
with "ada_ml_library.gpr";
project Mnist_Test_28x28 is

   for Target use "riscv64-elf";
   for Runtime ("Ada") use Bare_Runtime'Runtime ("Ada");

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Mnist_Test_28x28_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("mnist_test_28x28.adb");

   package Compiler is
      for Default_Switches ("Ada") use Mnist_Test_28x28_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatn", "-O3");
   end Compiler;

   package Linker is
      for Switches ("Ada") use ("-T", Neorv32_Hal'Project_Dir & "/src/link.ld"
      );
   end Linker;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Mnist_Test_28x28;
